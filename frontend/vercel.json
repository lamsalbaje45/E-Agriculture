{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "public": true,
  "env": {
    "VITE_APP_DOMAIN": "krishiconnect.np",
    "VITE_APP_NAME": "KrishiConnect"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://api.krishiconnect.np/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
